# Optional default goal for local CLI runs.
NENOYBOT_DEFAULT_GOAL=

# Reserved for future behavior tuning. Current accepted value: firm.
NENOYBOT_STRICTNESS=firm

# Timezone for Telegram reminders.
NENOYBOT_TIMEZONE=Europe/Moscow

# How often the worker checks due reminders.
NENOYBOT_REMINDER_CHECK_INTERVAL=30

# Telegram Bot API token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Long polling timeout in seconds.
TELEGRAM_POLL_TIMEOUT=30

# OpenAI API key. If empty, the bot falls back to the local keyword engine.
OPENAI_API_KEY=

# Default model for GPT analysis.
OPENAI_MODEL=gpt-5.5

# Neon/Postgres connection string. If empty, memory is process-local only.
DATABASE_URL=
